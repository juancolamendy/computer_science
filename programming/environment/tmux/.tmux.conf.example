# =============================================================================
# Tmux Configuration - Cross-Platform Compatible
# This config works on macOS, Ubuntu, and AlmaLinux
# =============================================================================

# =============================================================================
# Prefix
# =============================================================================
unbind C-b
set -g prefix C-a
bind C-a send-prefix

# =============================================================================
# Core settings
# =============================================================================
set -g default-terminal "tmux-256color"
set -ag terminal-overrides ",xterm-256color:RGB"

set -g renumber-windows on
set -sg escape-time 10
set -g focus-events on
set -g mouse on

# Increase history limit
set -g history-limit 10000

# =============================================================================
# Vi copy mode with Platform-Aware Clipboard
# =============================================================================
setw -g mode-keys vi
bind -T copy-mode-vi v send-keys -X begin-selection

# Platform detection for clipboard
# macOS uses pbcopy, Linux uses xclip/xsel
if-shell 'uname | grep -q Darwin' {
    # macOS - use pbcopy
    bind -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "pbcopy"
    bind -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "pbcopy"
} {
    # Linux - use xclip (more common than xsel)
    bind -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "xclip -selection clipboard -i"
    bind -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "xclip -selection clipboard -i"
}

# =============================================================================
# Splits & windows
# =============================================================================
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"
bind c new-window -c "#{pane_current_path}"

# =============================================================================
# Pane navigation (vim-style)
# =============================================================================
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

# =============================================================================
# Pane resizing
# =============================================================================
bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5

# =============================================================================
# Pane titles
# =============================================================================
set-hook -g after-split-window  'selectp -T ""'
set-hook -g after-new-window    'selectp -T ""'
set-hook -g after-new-session   'selectp -T ""'
set -g pane-border-status top
set -g pane-border-format " #{pane_index} #{?pane_title,#{pane_title},#{pane_current_command}} "
set -g pane-border-style        "fg=colour238"
set -g pane-active-border-style "fg=colour197"

# =============================================================================
# Key bindings
# =============================================================================
bind r     source-file ~/.tmux.conf \; display "Config reloaded"
bind-key P command-prompt -p " New panel name: " "select-pane -T '%%'"
bind-key C-p setw synchronize-panes

# Additional useful bindings
bind R source-file ~/.tmux.conf  # Capital R as alternative reload

# =============================================================================
# Status bar
# =============================================================================
set -g status-position bottom
set -g status-interval 1

# Base colors
set -g status-style "bg=colour237,fg=colour137"
set -g pane-active-border-style "fg=colour46"

# Left: session name + tasks if present
set -g status-left-length 70
set -g status-left "#[fg=colour81,bold] #S #[fg=colour238]│"

# Right: sync indicator · date · time · hostname
set -g status-right-length 100
set -g status-right "#{?pane_synchronized,#[bg=colour197 fg=colour232 bold] SYNC #[bg=colour235 fg=colour137],}#[fg=colour245] %a %m-%d #[fg=colour238]│#[fg=colour255 bold] %H:%M:%S #[fg=colour238]│#[fg=colour165] #H "

# Window list
set -g window-status-style         "fg=colour138"
set -g window-status-current-style "fg=colour46,bold"
set -g window-status-format         " #I:#W#F "
set -g window-status-current-format " #I:#W#F "
set -g window-status-separator      ""

# =============================================================================
# Plugins
# =============================================================================
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'

set -g @resurrect-capture-pane-contents 'on'
set -g @continuum-restore 'on'

# =============================================================================
# Initialize TPM (must be at the very end)
# =============================================================================
run '~/.tmux/plugins/tpm/tpm'
