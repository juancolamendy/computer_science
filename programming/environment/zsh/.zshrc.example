####### My Settings #######
## exports
### PATH
export PATH="/usr/local/sbin:$PATH"
### Private PATH
export PATH=$PATH:$HOME/bin

### Helm
export HELM_HOME=$HOME/.helm

### Java
export JAVA_HOME="/Library/Java/JavaVirtualMachines/openjdk.jdk/Contents/Home"
export PATH="$PATH:/opt/homebrew/opt/openjdk/bin"
export CPPFLAGS="-I/opt/homebrew/opt/openjdk/include"
# backward compatible
export JDK_JAVA_OPTIONS="--add-opens java.base/java.lang=ALL-UNNAMED"

### Go
export GOPATH=$HOME/go
export GOBIN=$GOPATH/bin
export GOROOT="/opt/homebrew/Cellar/go@1.23/1.23.6/libexec"
export GO111MODULE=on
export GOPROXY="https://proxy.golang.org,direct"
export GOSUMDB="sum.golang.org"
export GOPRIVATE=bitbucket.org/yourorg/*
export PATH=$PATH:$GOPATH/bin
export PATH=$PATH:$GOROOT/bin

### GCP
export PATH=$PATH:$HOME/opt/google-cloud-sdk/bin

## aliases
### Common
alias ll="ls -alh"
alias cdp="cd -P"
alias cpwd='pwd | pbcopy'
alias n='nvim'
alias fv="fzf --preview '([[ -f {} ]] && bat --style=numbers --color=always {}) || ([[ -d {} ]] && (tree -C {} | less))'"

### Python
alias pip=pip3
alias pye="python -m venv venv"
alias pyse="source venv/bin/activate"
alias pyde="deactivate"
### Jupyter
alias jupynote="jupyter notebook"
### uv
alias uvr='uv run'
alias uvi='uv init'
alias uvil='uv init --lib'
alias uve='uv venv'
alias uvse="source .venv/bin/activate"
alias uvde="deactivate"
alias uva='uv add'
alias uvrm='uv remove'

# Cursor ai
alias ca="cursor --add"

# Claude Code
alias claudex='claude --allowedTools "Bash,Write,Edit" --dangerously-skip-permissions'
alias claudext='claude --allowedTools "Bash,Write,Edit" --dangerously-skip-permissions --channels plugin:telegram@claude-plugins-official'

### Kubernetes
alias kvc='kubectl config get-contexts'
alias kvcc='kubectl config current-context'
alias kcc='kubectl config use-context'
alias k='kubectl'

### MacOS
alias nosleep='caffeinate'

### sqlite
alias sq3='sqlite3'
